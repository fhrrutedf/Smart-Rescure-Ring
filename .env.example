# 🚑 Smart Rescuer Ring - Environment Configuration

# --- AI & Analysis ---
# Google Gemini API Key (Required for Image Analysis)
# Get it from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API Key (Optional fallback for multiple AI models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Voice & Instructions ---
# ElevenLabs API Key (Required for High-Quality Arabic Voice)
# Get it from: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# --- Networking ---
# The IP address of your server. 
# Mobile devices MUST use the local IP (e.g., 192.168.x.x) not localhost.
PORT=5000
EXPO_PUBLIC_API_URL=http://192.168.0.11:5000

# --- Database ---
# PostgreSQL Connection String (Optional, defaults to Memory storage if empty)
DATABASE_URL=postgresql://user:pass@localhost:5432/smartrescuer
