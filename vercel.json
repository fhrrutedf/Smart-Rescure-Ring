{
  "version": 2,
  "builds": [
    {
      "src": "server/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/index.ts"
    },
    {
      "src": "/manifest",
      "dest": "server/index.ts"
    },
    {
      "src": "/dashboard",
      "dest": "server/index.ts"
    },
    {
      "src": "/static-build/(.*)",
      "dest": "/static-build/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "server/index.ts"
    }
  ]
}
